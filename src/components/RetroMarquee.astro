---
// Retro Marquee Component
export interface Props {
  visitorNumber?: string;
  lastUpdated?: string;
}

const { visitorNumber = '000001', lastUpdated = 'Today' } = Astro.props;
---

<div class="retro-marquee">
  <div class="retro-marquee-content">
    ★ Welcome To My Homepage! ★ You Are Visitor #{visitorNumber} ★ Last Updated: {lastUpdated} ★ Thanks For Stopping By! ★
  </div>
</div>

<style>
  .retro-marquee {
    background: #000080;
    color: #ffff00;
    font-family: "Comic Sans MS", cursive;
    padding: 8px 0;
    overflow: hidden;
    white-space: nowrap;
    border-top: 2px solid #ffffff;
    border-bottom: 2px solid #808080;
    margin: 16px 0;
  }

  .retro-marquee-content {
    display: inline-block;
    padding-left: 100%;
    animation: marquee-retro 15s linear infinite;
    font-weight: bold;
    font-size: 1.125rem;
  }

  @keyframes marquee-retro {
    0% { transform: translateX(0); }
    100% { transform: translateX(-100%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .retro-marquee-content {
      animation: none;
      padding-left: 0;
      text-align: center;
      width: 100%;
    }
  }
</style>
