---
import BaseLayout from '../layouts/BaseLayout.astro';
import RetroCounter from '../components/RetroCounter.astro';
import RetroMarquee from '../components/RetroMarquee.astro';
import RetroGuestbook from '../components/RetroGuestbook.astro';
---

<BaseLayout title="Zhu Jiaqi" description="Full-stack developer specializing in Python, Go, and AI-powered solutions">
  <div class="about-page">
    <!-- Retro elements - only visible in retro theme -->
    <div class="retro-elements">
      <RetroCounter />
      <RetroMarquee visitorNumber="000001" lastUpdated="March 2026" />
    </div>
    
    <section class="profile">
      <div class="profile-header">
        <div class="avatar-pixel-art">
          <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" shape-rendering="crispEdges">
            <rect x="0" y="0" width="32" height="32" fill="#1a1a2e"/>
            <rect x="8" y="4" width="16" height="6" fill="#2d2d44"/>
            <rect x="6" y="6" width="2" height="8" fill="#2d2d44"/>
            <rect x="24" y="6" width="2" height="8" fill="#2d2d44"/>
            <rect x="8" y="10" width="16" height="10" fill="#f5d0b0"/>
            <rect x="10" y="14" width="4" height="3" fill="#ffffff"/>
            <rect x="18" y="14" width="4" height="3" fill="#ffffff"/>
            <rect x="10" y="15" width="2" height="1" fill="#1a1a2e"/>
            <rect x="18" y="15" width="2" height="1" fill="#1a1a2e"/>
            <rect x="9" y="13" width="6" height="5" fill="none" stroke="#4a9eff" stroke-width="1"/>
            <rect x="17" y="13" width="6" height="5" fill="none" stroke="#4a9eff" stroke-width="1"/>
            <rect x="15" y="15" width="2" height="1" fill="#4a9eff"/>
            <rect x="13" y="17" width="6" height="1" fill="#d4a890"/>
            <rect x="10" y="20" width="12" height="8" fill="#3d5afe"/>
            <rect x="4" y="8" width="2" height="10" fill="#4a4a6a"/>
            <rect x="26" y="8" width="2" height="10" fill="#4a4a6a"/>
            <rect x="11" y="14" width="1" height="1" fill="#ffffff" opacity="0.6"/>
            <rect x="19" y="14" width="1" height="1" fill="#ffffff" opacity="0.6"/>
          </svg>
        </div>
        <h1>Zhu Jiaqi</h1>
        <p class="tagline">Full-Stack Developer · Python & Go Specialist · AI Enthusiast</p>
        <p class="birth-year">Born 1986</p>
      </div>
      
      <div class="contact-info">
        <a href="mailto:zjq426@gmail.com" class="contact-item">
          <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
          zjq426@gmail.com
        </a>
        <a href="https://github.com/zhujiaqi" class="contact-item" target="_blank" rel="noopener noreferrer">
          <svg class="icon" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          github.com/zhujiaqi
        </a>
      </div>
    </section>

    <section class="bio">
      <h2>About Me</h2>
      <p>
        I'm a seasoned full-stack developer with deep roots in backend engineering, having evolved 
        from specializing in Python and Go to architecting comprehensive solutions across the entire stack. 
        Since 2020, I've had the privilege of wearing multiple hats—from individual contributor to 
        engineering team lead—across diverse industries including location-based services, e-commerce, 
        and medical AI.
      </p>
      <p>
        My entrepreneurial spirit led me to co-found a startup with friends, where we built and marketed 
        our own brand of detox drinks and food products. This experience taught me invaluable lessons about 
        product-market fit, customer acquisition, and the realities of running a business beyond just writing code.
      </p>
      <p>
        Most recently, I've been deeply immersed in the AI revolution—studying LLM architectures, 
        experimenting with cutting-edge coding tools, and exploring frameworks like Claude Code. My passion 
        lies at the intersection of AI and developer productivity, constantly seeking ways to leverage 
        intelligent tools to build better software faster.
      </p>
    </section>

    <section class="experience">
      <h2>Professional Journey</h2>
      <div class="experience-grid">
        <div class="experience-item">
          <h3>🏢 Corporate Leadership</h3>
          <p>
            Led development teams while architecting scalable backend systems in Python and Go. 
            Worked across location-based services, e-commerce platforms, and medical AI applications, 
            gaining a broad perspective on how technology serves different industries.
          </p>
        </div>
        <div class="experience-item">
          <h3>🚀 AI Innovation</h3>
          <p>
            Currently developing an AI agent designed to democratize SaaS integration—transforming 
            product requirements documents (PRDs) directly into working code. This project represents 
            my belief in AI's potential to remove friction from the development process.
          </p>
        </div>
        <div class="experience-item">
          <h3>💼 Entrepreneurship</h3>
          <p>
            Co-founded a consumer health brand, taking it from concept to market. This venture 
            complemented my technical expertise with business acumen and a deeper understanding 
            of what it takes to build something from nothing.
          </p>
        </div>
      </div>
    </section>

    <section class="current-status">
      <h2>Current Focus</h2>
      <div class="status-card">
        <span class="status-indicator">👶</span>
        <div>
          <h3>Full-Time Parent & Independent Explorer</h3>
          <p>
            I'm currently not employed and have no plans to work for someone else in the near future. 
            My primary focus is caring for my newborn daughter—a role I cherish deeply. 
            Between diaper changes and nap times, I'm dedicating my learning hours to understanding 
            LLM models, testing emerging AI coding tools, and exploring the frontiers of what's possible 
            with AI-assisted development.
          </p>
          <p class="status-updated">Last updated: March 2026</p>
        </div>
      </div>
    </section>

    <section class="what-i-do">
      <h2>Expertise & Interests</h2>
      <ul class="activity-list">
        <li>
          <strong>Backend Engineering</strong>
          <span>Python, Go, distributed systems, API design</span>
        </li>
        <li>
          <strong>Full-Stack Development</strong>
          <span>End-to-end application architecture, modern web frameworks</span>
        </li>
        <li>
          <strong>AI & LLM Research</strong>
          <span>Studying model architectures, prompt engineering, AI coding tools</span>
        </li>
        <li>
          <strong>Team Leadership</strong>
          <span>Engineering management, mentoring, agile methodologies</span>
        </li>
        <li>
          <strong>Entrepreneurship</strong>
          <span>Product development, go-to-market strategy, customer discovery</span>
        </li>
      </ul>
    </section>

    <!-- Retro Guestbook - only visible in retro theme -->
    <div class="retro-elements">
      <RetroGuestbook />
    </div>
  </div>
</BaseLayout>

<style>
  .about-page { max-width: 720px; }
  .profile { text-align: center; margin-bottom: var(--space-2xl); }
  .profile-header { margin-bottom: var(--space-lg); }
  .avatar-pixel-art { width: 160px; height: 160px; margin: 0 auto var(--space-lg); image-rendering: pixelated; }
  .avatar-pixel-art svg { width: 100%; height: 100%; }
  .tagline { color: var(--color-text-secondary); font-size: 1.125rem; margin-top: var(--space-sm); }
  .birth-year { color: var(--color-text-muted); font-size: 0.875rem; margin-top: var(--space-xs); }
  .contact-info { display: flex; justify-content: center; gap: var(--space-xl); flex-wrap: wrap; }
  .contact-item { display: flex; align-items: center; gap: var(--space-sm); color: var(--color-text-secondary); font-size: 0.9375rem; }
  .contact-item:hover { color: var(--color-accent); text-decoration: none; }
  .icon { width: 18px; height: 18px; }
  section { margin-bottom: var(--space-2xl); }
  .bio p:last-child { margin-bottom: 0; }
  .experience-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: var(--space-lg); margin-top: var(--space-lg); }
  .experience-item { background-color: var(--color-bg-secondary); padding: var(--space-lg); border-radius: 8px; border: 1px solid var(--color-border); }
  .experience-item h3 { font-size: 1rem; margin-bottom: var(--space-sm); color: var(--color-text); }
  .experience-item p { font-size: 0.9375rem; color: var(--color-text-secondary); margin-bottom: 0; line-height: 1.6; }
  .current-status { background-color: var(--color-bg-secondary); padding: var(--space-lg); border-radius: 8px; border: 1px solid var(--color-border); }
  .status-card { display: flex; gap: var(--space-md); align-items: flex-start; }
  .status-indicator { font-size: 2rem; }
  .status-card h3 { margin-bottom: var(--space-sm); font-size: 1.125rem; }
  .status-updated { color: var(--color-text-muted); font-size: 0.8125rem; margin-top: var(--space-sm); }
  .activity-list { list-style: none; padding: 0; }
  .activity-list li { padding: 24px; border-bottom: 1px solid var(--color-border); }
  .activity-list li:last-child { border-bottom: none; }
  .activity-list strong { display: block; color: var(--color-text); margin-bottom: var(--space-xs); font-size: 1rem; }
  .activity-list span { color: var(--color-text-secondary); font-size: 0.9375rem; }
  
  /* Retro elements */
  .retro-elements { display: none; }
  .retro-theme .retro-elements { display: block; }
  .retro-theme .profile, .retro-theme .bio, .retro-theme .experience, .retro-theme .current-status, .retro-theme .what-i-do { 
    background: #c0c0c0; 
    border: 2px solid; 
    border-color: #ffffff #808080 #808080 #ffffff; 
    padding: 16px; 
    margin-bottom: 24px; 
  }
  .retro-theme .experience-grid { display: block; }
  .retro-theme .experience-item { margin-bottom: 16px; }
  .retro-theme .status-card { display: block; }
</style>

<style is:global>
  .retro-elements { display: none; }
  .retro-theme .retro-elements { display: block; }
</style>
