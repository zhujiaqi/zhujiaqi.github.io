---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About Me" description="Personal information and current status">
  <div class="about-page">
    <section class="profile">
      <div class="profile-header">
        <div class="avatar-placeholder">
          <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
            <circle cx="50" cy="50" r="48" fill="currentColor" opacity="0.1" />
            <circle cx="50" cy="40" r="20" fill="currentColor" opacity="0.3" />
            <ellipse cx="50" cy="85" rx="30" ry="25" fill="currentColor" opacity="0.3" />
          </svg>
        </div>
        <h1>Zhu Jiaqi</h1>
        <p class="tagline">Tech Enthusiast & Full-Stack Developer</p>
      </div>
      
      <div class="contact-info">
        <a href="mailto:contact@zjq.me" class="contact-item">
          <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
          contact@zjq.me
        </a>
        <a href="https://github.com/zhujiaqi" class="contact-item" target="_blank" rel="noopener noreferrer">
          <svg class="icon" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          github.com/zhujiaqi
        </a>
      </div>
    </section>

    <section class="bio">
      <h2>About Me</h2>
      <p>
        I'm a passionate developer who lives at the intersection of technology and innovation. 
        With years of experience building web applications and exploring cutting-edge technologies, 
        I've developed a deep appreciation for clean code, thoughtful architecture, and user-centric design.
      </p>
      <p>
        My journey in tech started with curiosity about how things work on the internet. 
        That curiosity has evolved into a career where I get to solve complex problems, 
        build scalable systems, and continuously learn from an amazing community of developers.
      </p>
      <p>
        When I'm not coding, you'll find me exploring new frameworks, contributing to open-source projects, 
        or sharing insights about the latest developments in our field.
      </p>
    </section>

    <section class="current-status">
      <h2>Current Status</h2>
      <div class="status-card">
        <span class="status-indicator">🟢</span>
        <div>
          <h3>Actively Building</h3>
          <p>
            Currently exploring the latest in AI-assisted development and modern web frameworks. 
            Focused on building performant, accessible web experiences with Astro and TypeScript.
          </p>
          <p class="status-updated">Last updated: March 2026</p>
        </div>
      </div>
    </section>

    <section class="what-i-do">
      <h2>What I Do</h2>
      <ul class="activity-list">
        <li>
          <strong>Full-Stack Development</strong>
          <span>Building end-to-end web applications with modern tech stacks</span>
        </li>
        <li>
          <strong>Performance Optimization</strong>
          <span>Making websites faster and more efficient</span>
        </li>
        <li>
          <strong>Technical Exploration</strong>
          <span>Staying ahead of emerging trends in AI and web development</span>
        </li>
        <li>
          <strong>Knowledge Sharing</strong>
          <span>Writing about learnings and best practices</span>
        </li>
      </ul>
    </section>
  </div>
</BaseLayout>

<style>
  .about-page {
    max-width: 680px;
  }

  .profile {
    text-align: center;
    margin-bottom: var(--space-2xl);
  }

  .profile-header {
    margin-bottom: var(--space-lg);
  }

  .avatar-placeholder {
    width: 120px;
    height: 120px;
    margin: 0 auto var(--space-lg);
    color: var(--color-accent);
  }

  .tagline {
    color: var(--color-text-secondary);
    font-size: 1.125rem;
    margin-top: var(--space-sm);
  }

  .contact-info {
    display: flex;
    justify-content: center;
    gap: var(--space-xl);
    flex-wrap: wrap;
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    color: var(--color-text-secondary);
    font-size: 0.9375rem;
  }

  .contact-item:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .icon {
    width: 18px;
    height: 18px;
  }

  section {
    margin-bottom: var(--space-2xl);
  }

  .bio p:last-child {
    margin-bottom: 0;
  }

  .current-status {
    background-color: var(--color-bg-secondary);
    padding: var(--space-lg);
    border-radius: 8px;
    border: 1px solid var(--color-border);
  }

  .status-card {
    display: flex;
    gap: var(--space-md);
    align-items: flex-start;
  }

  .status-indicator {
    font-size: 1.5rem;
  }

  .status-card h3 {
    margin-bottom: var(--space-xs);
    font-size: 1.125rem;
  }

  .status-updated {
    color: var(--color-text-muted);
    font-size: 0.8125rem;
    margin-top: var(--space-sm);
  }

  .activity-list {
    list-style: none;
    padding: 0;
  }

  .activity-list li {
    padding: var(--space-md) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .activity-list li:last-child {
    border-bottom: none;
  }

  .activity-list strong {
    display: block;
    color: var(--color-text);
    margin-bottom: var(--space-xs);
  }

  .activity-list span {
    color: var(--color-text-secondary);
    font-size: 0.9375rem;
  }
</style>
