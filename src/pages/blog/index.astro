---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => {
  return !data.draft;
})).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Blog" description="Articles about technology, web development, and AI">
  <section class="blog-page">
    <header class="blog-header">
      <h1>Blog</h1>
      <p class="blog-intro">
        Thoughts on web development, AI, and the ever-evolving tech landscape.
      </p>
    </header>

    <ul class="post-list">
      {posts.map((post) => (
        <li class="post-item">
          <a href={`/blog/${post.id}/`} class="post-link">
            <time datetime={post.data.pubDate.toISOString()} class="post-date">
              {post.data.pubDate.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric'
              })}
            </time>
            <h2 class="post-title">{post.data.title}</h2>
            {post.data.description && (
              <p class="post-description">{post.data.description}</p>
            )}
            {post.data.tags && post.data.tags.length > 0 && (
              <ul class="post-tags">
                {post.data.tags.map((tag) => (
                  <li class="tag">{tag}</li>
                ))}
              </ul>
            )}
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>

<style>
  .blog-page {
    max-width: 680px;
  }

  .blog-header {
    margin-bottom: var(--space-2xl);
  }

  .blog-intro {
    color: var(--color-text-secondary);
    font-size: 1.125rem;
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .post-item {
    margin-bottom: var(--space-xl);
    padding: var(--space-lg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .post-item:hover {
    border-color: var(--color-accent);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  }

  .post-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .post-link:hover {
    text-decoration: none;
  }

  .post-date {
    display: block;
    color: var(--color-text-muted);
    font-size: 0.875rem;
    margin-bottom: var(--space-sm);
  }

  .post-title {
    font-size: 1.25rem;
    margin-bottom: var(--space-sm);
    color: var(--color-text);
  }

  .post-description {
    color: var(--color-text-secondary);
    margin-bottom: var(--space-sm);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .tag {
    background-color: var(--color-bg-secondary);
    color: var(--color-text-secondary);
    font-size: 0.75rem;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    font-weight: 500;
  }
</style>
